---
import Logo from './Logo.astro';
import { getCategories } from '../lib/queries';
const links = [
  { href: '/', label: 'Home' },
  { href: '/collections', label: 'Collections' },
  { href: '/catalog', label: 'Catalog' },
  { href: '/free', label: 'Free files' },
  { href: '/about', label: 'Our story' },
  { href: '/blog', label: 'Blog' },
  { href: '/account', label: 'User Portal' },
];
const q = Astro.url.searchParams.get('q') ?? '';
const categories = await getCategories();
---
<div class="bg-bronze-800 text-cream text-xs text-center py-1.5">
  Instant digital download · Commercial use included · 4.9★ from 577 reviews
</div>
<header class="sticky top-0 bg-white z-30 border-b border-black/10">
  <nav class="flex items-center gap-3 px-4 sm:px-6 py-3 max-w-7xl mx-auto">
    <!-- Hamburger: visible on mobile/tablet only -->
    <button id="dcc-menu-open" class="lg:hidden text-bronze-700 text-2xl leading-none w-9 h-9 -ml-1 rounded hover:bg-cream" aria-label="Open menu" aria-controls="dcc-drawer" aria-expanded="false">☰</button>
    <Logo />
    <form action="/search" method="get" role="search" class="hidden md:flex flex-1 min-w-0 max-w-xs xl:max-w-md mx-2">
      <input type="search" name="q" value={q} placeholder="Search STL files…" aria-label="Search STL files"
        class="flex-1 px-4 py-2 text-sm rounded-l-md border border-r-0 border-black/15 focus:outline-none focus:border-bronze-600" />
      <button class="bg-bronze-600 text-cream px-4 rounded-r-md text-sm" aria-label="Search">Search</button>
    </form>
    <div class="hidden lg:flex gap-4 text-sm text-ink-700 lg:ml-auto whitespace-nowrap">
      {links.map((l) => <a href={l.href} class={`hover:text-bronze-600 ${l.href === '/free' ? 'text-bronze-600' : ''}`}>{l.label}</a>)}
    </div>
    <div class="flex gap-3 text-sm text-ink-700 ml-auto lg:ml-3 items-center whitespace-nowrap shrink-0">
      <a href="/membership" class="hidden xl:inline-block text-bronze-600 font-medium" aria-label="Become a member">Become a member</a>
      <a href="/cart" class="font-medium text-ink-800 hover:text-bronze-600" aria-label="Cart">🛒 Cart <span id="cart-count" class="text-bronze-600 font-medium"></span></a>
    </div>
  </nav>
  <form action="/search" method="get" role="search" class="md:hidden px-4 pb-3 flex">
    <input type="search" name="q" value={q} placeholder="Search STL files…" aria-label="Search STL files"
      class="flex-1 px-4 py-2 text-sm rounded-l-md border border-r-0 border-black/15 focus:outline-none focus:border-bronze-600" />
    <button class="bg-bronze-600 text-cream px-4 rounded-r-md text-sm">Go</button>
  </form>
</header>

<!-- Mobile drawer: nav links + category list — same content the desktop header + sidebar show -->
<div id="dcc-drawer-overlay" class="hidden lg:hidden fixed inset-0 bg-black/40 z-40" aria-hidden="true"></div>
<aside id="dcc-drawer" class="lg:hidden fixed top-0 left-0 h-full w-[280px] max-w-[85vw] bg-white shadow-xl z-50 -translate-x-full transition-transform duration-200 overflow-y-auto" role="dialog" aria-modal="true" aria-label="Site navigation">
  <div class="flex items-center justify-between px-4 py-3 border-b border-black/10">
    <span class="font-serif text-bronze-700">Menu</span>
    <button id="dcc-menu-close" class="text-bronze-700 text-2xl leading-none w-9 h-9 rounded hover:bg-cream" aria-label="Close menu">✕</button>
  </div>
  <nav class="py-2 text-sm">
    {links.map((l) => (
      <a href={l.href} class={`block px-4 py-2.5 hover:bg-cream ${l.href === '/free' ? 'text-bronze-600 font-medium' : 'text-ink-800'}`}>{l.label}</a>
    ))}
    <a href="/membership" class="block px-4 py-2.5 text-bronze-600 font-medium hover:bg-cream">Become a member</a>
    <a href="/cart" class="block px-4 py-2.5 text-ink-800 hover:bg-cream">Cart</a>
  </nav>
  <div class="border-t border-black/10 px-4 py-3">
    <h2 class="text-[11px] font-medium text-ink-700/60 uppercase tracking-wide mb-2">Categories</h2>
    <nav class="text-sm space-y-0.5">
      <a href="/catalog" class="block py-1.5 px-2 rounded text-bronze-700 font-medium hover:bg-cream">All designs</a>
      {categories.map((c) => (
        <a href={`/collections/${c.slug}`} class="block py-1.5 px-2 rounded text-ink-700 hover:bg-cream">{c.name}</a>
      ))}
    </nav>
  </div>
</aside>
<script is:inline>
  function cartCount() { try { return JSON.parse(localStorage.getItem('cart') || '[]').length; } catch { return 0; } }
  function renderCartCount() { const el = document.getElementById('cart-count'); if (el) { const n = cartCount(); el.textContent = n > 0 ? `(${n})` : ''; } }
  renderCartCount();
  window.addEventListener('cart-changed', renderCartCount);
  window.addEventListener('storage', renderCartCount);

  // ── Mobile drawer (nav + categories) ──────────────────────────────
  const _drawer = document.getElementById('dcc-drawer');
  const _overlay = document.getElementById('dcc-drawer-overlay');
  const _openBtn = document.getElementById('dcc-menu-open');
  const _closeBtn = document.getElementById('dcc-menu-close');
  function openDrawer() {
    _drawer?.classList.remove('-translate-x-full');
    _overlay?.classList.remove('hidden');
    _openBtn?.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
  }
  function closeDrawer() {
    _drawer?.classList.add('-translate-x-full');
    _overlay?.classList.add('hidden');
    _openBtn?.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
  }
  _openBtn?.addEventListener('click', openDrawer);
  _closeBtn?.addEventListener('click', closeDrawer);
  _overlay?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });

  // Reflect cart membership on every .add-to-cart button (turns green "✓ In cart").
  function syncCartButtons() {
    let cart = [];
    try { cart = JSON.parse(localStorage.getItem('cart') || '[]'); } catch {}
    const ids = new Set(cart.map((x) => x.id));
    document.querySelectorAll('.add-to-cart[data-id]').forEach((btn) => {
      const inCart = ids.has(btn.dataset.id);
      btn.classList.toggle('in-cart', inCart);
      btn.textContent = inCart ? '✓ In cart' : 'Add to cart';
    });
  }
  window.dccSyncCartButtons = syncCartButtons;
  syncCartButtons();
  window.addEventListener('cart-changed', syncCartButtons);
  window.addEventListener('storage', syncCartButtons);

  // Delegated "Add to cart" for any .add-to-cart button site-wide (product cards, etc.)
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('.add-to-cart');
    if (!btn) return;
    e.preventDefault();
    const d = btn.dataset;
    const cart = JSON.parse(localStorage.getItem('cart') || '[]');
    if (cart.find((x) => x.id === d.id)) { window.location.href = '/cart'; return; } // already added → go to cart
    cart.push({ id: d.id, slug: d.slug, title: d.title, price: Number(d.price), img: d.img });
    localStorage.setItem('cart', JSON.stringify(cart));
    window.dispatchEvent(new Event('cart-changed'));
    syncCartButtons();
  });
</script>
