---
// One "Carved by you" entry: the maker's story on the left, the finished
// carving shown in FULL (object-contain, never cropped) on the right, on a
// warm cream panel that matches the brand. Stacks (image on top, story below)
// on mobile, sits side by side from sm+.
interface Props { creation: any; }
const { creation: c } = Astro.props;
const linkHref = c.products?.slug ? `/product/${c.products.slug}` : (c.product_url || null);
// Drop a leading "Customer Spotlight: …" line if present; keep the rest as the story.
const story = (c.description || '').replace(/^\s*customer spotlight:[^\n]*\n+/i, '').trim();
const img = (c.gallery && c.gallery[0]) || null;
---
<article class="w-[300px] sm:w-[600px] flex-shrink-0 bg-white border border-black/10 rounded-xl overflow-hidden flex flex-col sm:flex-row shadow-sm">
  <!-- Story — left on desktop, below the image on mobile -->
  <div class="sm:w-[44%] p-5 flex flex-col justify-center order-2 sm:order-1">
    <div class="text-[10px] tracking-[0.18em] text-bronze-600 uppercase mb-1.5">★ Maker spotlight</div>
    <h3 class="font-serif text-lg sm:text-xl text-bronze-800 leading-tight">{c.name}</h3>
    {story && <p class="mt-2 text-xs sm:text-sm text-ink-700/85 leading-relaxed line-clamp-6">{story}</p>}
    {linkHref && (
      <a href={linkHref} class="mt-3 inline-block text-xs font-medium text-bronze-700 hover:underline whitespace-nowrap">
        Shop this design →
      </a>
    )}
  </div>
  <!-- Image — full, never cropped — right on desktop, top on mobile -->
  <div class="sm:w-[56%] bg-cream flex items-center justify-center p-2.5 order-1 sm:order-2 min-h-[180px]">
    {img
      ? <img src={img} alt={`Bas-relief carving by ${c.name}`} loading="lazy" class="w-full max-h-[320px] object-contain rounded-lg" />
      : <div class="text-bronze-600/40 font-serif text-sm">{c.name}</div>}
  </div>
</article>
