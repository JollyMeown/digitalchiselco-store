---
import { getSettings } from '../lib/queries';
const s = await getSettings();
const donation = Math.round(Number(s.donation_total)).toLocaleString();
---
<section class="bg-bronze-800 text-cream text-center py-8 px-6">
  <p class="text-sm">Together we've donated</p>
  <p class="font-serif text-3xl text-[#FAC775] my-1">${donation} &amp; counting</p>
  <p class="text-xs opacity-80">50% of every sale supports charitable causes</p>
</section>
<footer class="px-6 py-10 text-center text-xs text-ink-700/60 border-t border-black/10">
  <div class="flex gap-4 justify-center mb-3 flex-wrap">
    <a href="/catalog">Catalog</a><a href="/collections">Collections</a><a href="/free">Free files</a>
    <a href="/about">About</a><a href="/blog">Blog</a><a href="/contact">Contact</a>
  </div>
  <p>© {new Date().getFullYear()} DigitalChiselCo · Premium STL files for CNC, laser &amp; 3D printing</p>
  <p class="mt-1">Questions? <a href="mailto:jolly@digitalchiselco.com" class="text-bronze-600">jolly@digitalchiselco.com</a></p>
</footer>
