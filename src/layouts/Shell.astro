---
// Two-column storefront shell: left category menu + content.
// Use on every storefront page EXCEPT cart / checkout (those use Base directly).
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideMenu from '../components/SideMenu.astro';
import SiteBanner from '../components/SiteBanner.astro';

interface Props { title?: string; description?: string; image?: string; noindex?: boolean; fullWidth?: boolean; hideBanner?: boolean; scrollPastBanner?: boolean; ogType?: string; price?: number; currency?: string; availability?: string; }
const { title, description, image, noindex, fullWidth = false, hideBanner = false, scrollPastBanner = false, ogType, price, currency, availability } = Astro.props;
---
<Base title={title} description={description} image={image} noindex={noindex} ogType={ogType} price={price} currency={currency} availability={availability}>
  <Header />
  {!hideBanner && <SiteBanner />}
  {scrollPastBanner && !hideBanner && (
    <script is:inline>
      (function () {
        function scrollPast() {
          var banner = document.getElementById('site-banner');
          if (!banner) return;
          var header = document.querySelector('header.sticky');
          var headerH = header ? header.offsetHeight : 0;
          var rect = banner.getBoundingClientRect();
          var bottom = rect.top + window.pageYOffset + rect.height;
          var target = Math.max(0, bottom - headerH);
          var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          // Brief pause so the banner is visible before the gentle scroll begins.
          setTimeout(function () {
            window.scrollTo({ top: target, behavior: reduceMotion ? 'auto' : 'smooth' });
          }, 250);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', scrollPast);
        } else {
          scrollPast();
        }
      })();
    </script>
  )}
  {fullWidth ? (
    <slot />
  ) : (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 flex gap-8">
      <SideMenu />
      <div class="flex-1 min-w-0">
        <slot />
      </div>
    </div>
  )}
  <Footer />
</Base>
