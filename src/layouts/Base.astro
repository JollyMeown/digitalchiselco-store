---
import '../styles/global.css';
import { getSettings } from '../lib/queries';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
interface Props { title?: string; description?: string; image?: string; noindex?: boolean; ogType?: string; price?: number; currency?: string; availability?: string; }
const {
  title = 'DigitalChiselCo — Premium STL Files for CNC, Laser & 3D Printing',
  description = 'Hundreds of museum-grade bas-relief STL files for CNC routers, 3D printers and laser engravers. Instant download, commercial use included.',
  image = '/og-default.jpg',
  noindex = false,
  ogType = 'website',
  price,
  currency = 'USD',
  availability = 'in stock',
} = Astro.props;
// Product Rich Pin metadata — emitted only on product pages (ogType === 'product').
const priceAmount = typeof price === 'number' ? price.toFixed(2) : null;
const site = import.meta.env.PUBLIC_SITE_URL || 'https://digitalchiselco.com';
// GA4 — defaults to the project's measurement ID. Override per-environment via
// the Netlify env var PUBLIC_GA_MEASUREMENT_ID (e.g. a staging stream).
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-MB5KF3D03Y';
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = image.startsWith('http') ? image : new URL(image, site).href;
const settings = await getSettings();
const faviconUrl = settings.favicon_image_url || '/favicon.svg';
const faviconType = settings.favicon_image_url
  ? (settings.favicon_image_url.endsWith('.svg') ? 'image/svg+xml'
    : settings.favicon_image_url.endsWith('.png') ? 'image/png'
    : settings.favicon_image_url.endsWith('.ico') ? 'image/x-icon'
    : 'image/jpeg')
  : 'image/svg+xml';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" type={faviconType} href={faviconUrl} />
    {settings.favicon_image_url && <link rel="apple-touch-icon" href={settings.favicon_image_url} />}
    <meta name="theme-color" content="#854F0B" />
    <!-- Pinterest domain claim verification -->
    <meta name="p:domain_verify" content="eb94c29164f0c191df3c86dfea001abd" />
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="DigitalChiselCo" />
    {ogType === 'product' && priceAmount && (
      <>
        {/* Product Rich Pin tags — let Pinterest show live price + availability on organic pins */}
        <meta property="product:price:amount" content={priceAmount} />
        <meta property="product:price:currency" content={currency} />
        <meta property="product:availability" content={availability} />
        <meta property="og:price:amount" content={priceAmount} />
        <meta property="og:price:currency" content={currency} />
      </>
    )}
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Preconnect to our image CDN (Supabase Storage) for faster product/category image loads */}
    <link rel="preconnect" href="https://tutalnieozbngrsfywes.supabase.co" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..600;1,9..144,400..600&family=Instrument+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="overflow-x-clip">
    <AnnouncementBanner />
    <slot />
    <!-- Organization + WebSite structured data — helps Google build Knowledge Graph
         entries for the brand and enables the sitelinks search box. -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Organization',
          '@id': site + '#org',
          name: 'DigitalChiselCo',
          url: site,
          logo: settings.logo_image_url || (site + '/og-default.jpg'),
          email: settings.admin_email || 'jolly@digitalchiselco.com',
          sameAs: [],
          description: 'Premium bas-relief STL files for CNC routers, laser engravers and 3D printers.',
        },
        {
          '@type': 'WebSite',
          '@id': site + '#website',
          name: 'DigitalChiselCo',
          url: site,
          publisher: { '@id': site + '#org' },
          potentialAction: {
            '@type': 'SearchAction',
            target: { '@type': 'EntryPoint', urlTemplate: site + '/search?q={search_term_string}' },
            'query-input': 'required name=search_term_string',
          },
        },
      ],
    })} />
  </body>
</html>
