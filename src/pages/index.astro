---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideMenu from '../components/SideMenu.astro';
import SiteBanner from '../components/SiteBanner.astro';
import ProductCard from '../components/ProductCard.astro';
import Marquee from '../components/Marquee.astro';
import {
  getCategories, getProducts, getSettings,
  getBestSellers, getLatestProducts, getReviews, getFaqs, getMembershipPlans,
} from '../lib/queries';

const s = await getSettings();
const categories = await getCategories();
const [bestsellers, latest, reviews, faqs, plans, { products }] = await Promise.all([
  getBestSellers(12),
  getLatestProducts(8),
  getReviews(12),
  getFaqs(20),
  getMembershipPlans(),
  getProducts(1, 24),
]);

// fallback bestsellers if admin hasn't flagged any yet — use first 8 with images
const showBest = bestsellers.length > 0 ? bestsellers : products.filter((p) => p.image_url).slice(0, 8);
const featuredPlan = plans.find((p) => p.highlight) || plans[0];
---
<Base>
  <Header />
  <SiteBanner />

  <!-- Trust strip -->
  <div class="bg-cream/40 border-y border-black/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 text-center text-xs text-ink-700">
      {s.trust_badges.map((b) => (
        <div class="flex items-center justify-center gap-2 py-1">
          <span class="text-lg leading-none text-bronze-600">{b.icon}</span>
          <span class="font-medium">{b.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Stats row -->
  <div class="bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      <div>
        <div class="font-serif text-2xl md:text-3xl text-bronze-700">{Number(s.sales_count).toLocaleString()}+</div>
        <div class="text-[11px] uppercase tracking-widest text-ink-700/70 mt-1">STL Files Sold</div>
      </div>
      <div>
        <div class="font-serif text-2xl md:text-3xl text-bronze-700">{Number(s.rating)} <span class="text-yellow-500">★</span></div>
        <div class="text-[11px] uppercase tracking-widest text-ink-700/70 mt-1">Avg. Rating · {s.reviews_count}+ Reviews</div>
      </div>
      <div>
        <div class="font-serif text-2xl md:text-3xl text-bronze-700">{Number(s.products_count).toLocaleString()}+</div>
        <div class="text-[11px] uppercase tracking-widest text-ink-700/70 mt-1">Unique Designs</div>
      </div>
      <div>
        <div class="font-serif text-2xl md:text-3xl text-bronze-700">{Number(s.experience_years)}+</div>
        <div class="text-[11px] uppercase tracking-widest text-ink-700/70 mt-1">Years of Craftsmanship</div>
      </div>
    </div>
  </div>

  <!-- Main grid: side menu + content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 flex gap-8">
    <SideMenu />
    <div class="flex-1 min-w-0 space-y-14">

      <!-- Shop by collection -->
      <section>
        <div class="flex justify-between items-baseline mb-5">
          <h2 class="font-serif text-2xl text-ink-800">Shop by collection</h2>
          <a href="/collections" class="text-sm text-bronze-600 hover:underline">View all →</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {categories.slice(0, 6).map((c) => (
            <a href={`/collections/${c.slug}`} class="block border border-black/10 rounded-lg overflow-hidden hover:shadow-md transition group">
              <div class="aspect-[16/9] bg-cream overflow-hidden">
                {c.image_url
                  ? <img src={c.image_url} alt={c.name} loading="lazy" class="w-full h-full object-cover group-hover:scale-[1.04] transition duration-500" />
                  : <div class="w-full h-full flex items-center justify-center font-serif text-bronze-600/50 text-center px-3">{c.name}</div>}
              </div>
              {!c.image_url && <div class="p-3 text-sm">{c.name}</div>}
            </a>
          ))}
        </div>
      </section>

      <!-- Become a member CTA -->
      {featuredPlan && (
        <section class="border border-bronze-600/20 rounded-2xl bg-gradient-to-br from-cream to-white p-6 md:p-8">
          <div class="grid md:grid-cols-2 gap-6 items-center">
            <div>
              <p class="text-xs tracking-widest text-bronze-600 mb-2">★ MOST POPULAR PLAN</p>
              <h2 class="font-serif text-3xl text-bronze-800 leading-tight">{s.membership_title}</h2>
              <p class="mt-3 text-ink-700/85 leading-relaxed">{s.membership_subtitle}</p>
              <ul class="mt-4 text-sm text-ink-700 space-y-1.5">
                {featuredPlan.features.slice(0, 4).map((f) => (
                  <li class="flex gap-2"><span class="text-bronze-600">✓</span>{f}</li>
                ))}
              </ul>
              <div class="mt-6 flex flex-wrap gap-3">
                <a href="/membership" class="bg-bronze-600 text-cream px-6 py-3 rounded-md text-sm hover:bg-bronze-700 transition shadow-sm">
                  Become a member — ${Number(featuredPlan.price_usd).toFixed(2)}
                </a>
                <a href="/membership" class="border border-bronze-600 text-bronze-700 px-6 py-3 rounded-md text-sm hover:bg-bronze-600/10 transition">
                  Lock in your low price →
                </a>
              </div>
            </div>
            <div class="order-first md:order-last">
              {s.membership_image_url
                ? <img src={s.membership_image_url} alt="Premium Membership poster" class="w-full h-auto rounded-lg shadow-md max-h-[440px] object-contain bg-cream" />
                : <div class="aspect-[3/4] bg-cream rounded-lg flex items-center justify-center text-bronze-600/40 font-serif text-center px-6 max-h-[440px]">
                    Upload the Premium Membership poster in admin → Media & Hero → "Membership card"
                  </div>}
            </div>
          </div>
        </section>
      )}

      <!-- Best Sellers (admin-selected) — animated marquee -->
      {showBest.length > 0 && (
        <section>
          <div class="flex justify-between items-baseline mb-4">
            <h2 class="font-serif text-2xl text-ink-800">★ Best Sellers</h2>
            <a href="/catalog" class="text-sm text-bronze-600 hover:underline">Shop all →</a>
          </div>
          <Marquee duration={50}>
            {showBest.map((p) => (
              <div class="w-[200px] sm:w-[220px]"><ProductCard product={p} discount={s.discount_percent} /></div>
            ))}
          </Marquee>
          <p class="text-xs text-ink-700/50 mt-2 text-right">Hover to pause · set bestsellers in admin → Products → "★ Best seller"</p>
        </section>
      )}

      <!-- Latest 3D Designs -->
      {latest.length > 0 && (
        <section>
          <div class="flex justify-between items-baseline mb-4">
            <h2 class="font-serif text-2xl text-ink-800">Latest 3D Designs</h2>
            <a href="/catalog" class="text-sm text-bronze-600 hover:underline">Browse catalog →</a>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {latest.slice(0, 8).map((p) => <ProductCard product={p} discount={s.discount_percent} />)}
          </div>
        </section>
      )}
    </div>
  </div>

  <!-- Loved by makers — DB-driven, scrolling marquee -->
  {reviews.length > 0 && (
    <section class="bg-cream/60 py-12">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-7">
          <h2 class="font-serif text-3xl md:text-4xl text-bronze-800">Loved by makers</h2>
          <p class="text-sm text-bronze-700 mt-2">★★★★★ {Number(s.rating)} average · {s.reviews_count}+ verified reviews</p>
        </div>
        <Marquee duration={60} direction="right">
          {reviews.map((r) => (
            <figure class="w-[300px] md:w-[340px] bg-white border border-black/10 rounded-lg p-5">
              <div class="text-bronze-600 mb-2 text-sm">{'★'.repeat(r.rating)}{'☆'.repeat(5 - r.rating)}</div>
              <blockquote class="text-sm text-ink-700 leading-relaxed">"{r.text}"</blockquote>
              <figcaption class="mt-3 text-sm font-medium text-ink-800">— {r.name}{r.source ? <span class="text-ink-700/50 font-normal"> · {r.source}</span> : null}</figcaption>
            </figure>
          ))}
        </Marquee>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faqs.length > 0 && (
    <section class="max-w-3xl mx-auto px-4 sm:px-6 py-14">
      <h2 class="font-serif text-2xl text-center mb-8">Frequently asked questions</h2>
      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="dcc-faq border border-black/10 rounded-lg overflow-hidden bg-white">
            <summary class="cursor-pointer font-medium text-ink-800 list-none flex justify-between items-center p-4 hover:bg-cream/50 transition">
              <span>{f.question}</span>
              <span class="text-bronze-600 text-xl leading-none transition-transform">+</span>
            </summary>
            <div class="px-4 pb-4 text-sm text-ink-700 leading-relaxed whitespace-pre-line">{f.answer}</div>
          </details>
        ))}
      </div>
    </section>
  )}
  <style>
    .dcc-faq[open] summary > span:last-child { transform: rotate(45deg); }
    .dcc-faq > div { animation: dcc-fade 0.25s ease-out; }
    @keyframes dcc-fade { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
  </style>

  <!-- Free files lead magnet -->
  <section class="bg-cream/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 grid md:grid-cols-2 gap-8 items-center">
      <div class="dcc-free-img-wrap aspect-[4/3] bg-cream rounded-lg overflow-hidden border border-black/10">
        {s.free_image_url
          ? <img src={s.free_image_url} alt="Free STL files pack" class="w-full h-full object-cover dcc-free-img" />
          : <div class="w-full h-full flex items-center justify-center text-bronze-600/40 font-serif text-center px-6">Upload a "free pack" image in admin → Media & Hero</div>}
      </div>
      <div>
        <p class="text-xs tracking-widest text-bronze-600 mb-2">★ FREE FROM OUR STUDIO</p>
        <h2 class="font-serif text-3xl text-bronze-800 leading-tight">Try five of our <em class="italic">most carved</em> files, on the house.</h2>
        <p class="mt-4 text-ink-700">Drop your email and we'll send five hand-picked premium bas-relief STL files, plus a short PDF on scaling and finishing — everything tested on real CNC routers, 3D printers and laser engravers.</p>
        <a href="/free" class="mt-6 inline-block bg-bronze-600 text-cream px-6 py-3 rounded-md text-sm hover:bg-bronze-700 transition">Send me the pack →</a>
        <p class="text-xs text-ink-700/50 mt-2">No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>
  <style>
    .dcc-free-img { transition: transform 0.6s ease; }
    .dcc-free-img-wrap:hover .dcc-free-img { transform: scale(1.05); }
  </style>

  <!-- Closing brand strip (product-focused) -->
  <section class="bg-bronze-800 text-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 text-center">
      <p class="text-xs tracking-widest text-[#FAC775] mb-2">★ DIGITALCHISELCO STUDIO</p>
      <p class="font-serif text-2xl md:text-3xl leading-snug max-w-3xl mx-auto">Hand-finished bas-relief STL designs built for serious CNC, laser, and 3D-print makers.</p>
      <p class="mt-4 text-sm text-cream/80 max-w-2xl mx-auto">Every file is tested on real machines before it ships. Commercial use is included on every purchase — sell the pieces you carve.</p>
      <a href="/catalog" class="mt-6 inline-block bg-[#FAC775] text-bronze-900 px-6 py-3 rounded-md text-sm font-medium hover:opacity-90 transition">Browse the catalog →</a>
    </div>
  </section>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.question, acceptedAnswer: { '@type': 'Answer', text: f.answer } })),
  })} />
</Base>
