---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SideMenu from '../components/SideMenu.astro';
import SiteBanner from '../components/SiteBanner.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCategories, getProducts, getSettings, getProductById } from '../lib/queries';

const s = await getSettings();
const categories = await getCategories();
const { products } = await getProducts(1, 24);
const withImg = products.filter((p) => p.image_url);

// hero image: admin upload > featured product image > first product with image
let heroImg = s.hero_image_url;
if (!heroImg && s.featured_product_id) {
  const featured = await getProductById(s.featured_product_id);
  heroImg = featured?.image_url || null;
}
if (!heroImg) heroImg = withImg[0]?.image_url || null;

const bestsellers = withImg.slice(0, 12).filter((p) => p.image_url !== heroImg).slice(0, 10);

const reviews = [
  { name: 'Vickie', text: 'The value of this purchase is amazing. They are all top quality. Easy downloads, works perfectly with the Vcarve software. Thank you so much!' },
  { name: 'Diane', text: 'Love these, and seller is very good with help! Would definitely recommend! And they are awesome with the customized files.' },
  { name: 'Clyde', text: 'Nice finish carving with great detail. Quality, new products for this CNC wood carver. I will get more.' },
];
const faqs = [
  { q: 'What file format do I get?', a: 'High-detail STL files, ready for CNC routers, 3D printers and laser engravers. Tested in Aspire, VCarve Pro, Carveco, ArtCAM and Fusion 360.' },
  { q: 'How do I receive my files after buying?', a: 'Instantly. You get a secure download link by email the moment your payment clears, and the files also appear in your account dashboard to re-download anytime.' },
  { q: 'Can I use the designs commercially?', a: 'Yes — every purchase includes a personal and commercial-use license, so you can sell the items you carve or print.' },
  { q: 'What is the 50% donation?', a: `We donate 50% of every sale to people in need and animal welfare. Together our customers have already donated $${Math.round(Number(s.donation_total)).toLocaleString()}.` },
  { q: 'Do you take custom orders?', a: 'Yes! We create custom bas-relief portraits and designs from your photos. See our Custom Commissions collection or contact us.' },
];
---
<Base>
  <Header />
  <SiteBanner />

  <!-- hero -->
  <header class="bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="text-xs tracking-widest text-bronze-600 mb-3">PREMIUM STL FILES · CNC · LASER · 3D PRINT</p>
        <h1 class="text-4xl md:text-5xl text-bronze-800 leading-tight">{s.hero_headline}</h1>
        <p class="mt-5 text-bronze-700 max-w-md">{s.hero_subhead}</p>
        <div class="mt-7 flex gap-3 flex-wrap">
          <a href="/catalog" class="bg-bronze-600 text-cream text-sm px-6 py-3 rounded-md hover:bg-bronze-700 transition">Shop collections</a>
          <a href="/free" class="border border-bronze-600 text-bronze-800 text-sm px-6 py-3 rounded-md hover:bg-bronze-600/10 transition">Get 5 free STL files</a>
        </div>
        <p class="mt-5 text-sm text-bronze-700">★★★★★ &nbsp;{Number(s.rating)} from {s.reviews_count} reviews · {Number(s.sales_count).toLocaleString()} sales · {Number(s.admirers_count).toLocaleString()} admirers</p>
      </div>
      <div class="aspect-square rounded-xl overflow-hidden shadow-sm bg-white/40">
        {heroImg && <img src={heroImg} alt="Featured bas-relief STL wood carving design" width="700" height="700" class="w-full h-full object-cover" />}
      </div>
    </div>
  </header>

  <!-- trust strip -->
  <div class="grid grid-cols-2 md:grid-cols-4 border-y border-black/10 text-center text-xs text-ink-700">
    <div class="py-4 border-r border-black/10">Instant download</div>
    <div class="py-4 border-r border-black/10">Secure checkout</div>
    <div class="py-4 border-r border-black/10">50% to charity</div>
    <div class="py-4">Commercial license</div>
  </div>

  <!-- main: left category menu + content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 flex gap-8">
    <SideMenu />
    <div class="flex-1 min-w-0">
      <section class="mb-12">
        <div class="flex justify-between items-baseline mb-5">
          <h2 class="text-2xl">Shop by collection</h2>
          <a href="/collections" class="text-sm text-bronze-600">View all →</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {categories.slice(0, 6).map((c) => (
            <a href={`/collections/${c.slug}`} class="block border border-black/10 rounded-lg overflow-hidden hover:shadow-md transition group">
              <div class="aspect-[16/9] bg-cream overflow-hidden">
                {c.image_url
                  ? <img src={c.image_url} alt={c.name} loading="lazy" class="w-full h-full object-cover group-hover:scale-[1.03] transition" />
                  : <div class="w-full h-full flex items-center justify-center font-serif text-bronze-600/50 text-center px-3">{c.name}</div>}
              </div>
              {!c.image_url && <div class="p-3 text-sm">{c.name}</div>}
            </a>
          ))}
        </div>
      </section>

      {bestsellers.length > 0 && (
        <section>
          <h2 class="text-2xl mb-5">Popular designs</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {bestsellers.map((p) => <ProductCard product={p} discount={s.discount_percent} />)}
          </div>
        </section>
      )}
    </div>
  </div>

  <!-- reviews -->
  <section class="bg-cream/60 py-12">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-8">
        <h2 class="text-2xl">Loved by makers</h2>
        <p class="text-sm text-bronze-700 mt-1">★★★★★ {Number(s.rating)} average · {s.reviews_count}+ verified reviews</p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {reviews.map((r) => (
          <figure class="bg-white border border-black/10 rounded-lg p-5">
            <div class="text-bronze-600 mb-2">★★★★★</div>
            <blockquote class="text-sm text-ink-700 leading-relaxed">“{r.text}”</blockquote>
            <figcaption class="mt-3 text-sm font-medium">— {r.name}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-6 py-14">
    <h2 class="text-2xl text-center mb-8">Frequently asked questions</h2>
    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="border border-black/10 rounded-lg p-4 group">
          <summary class="cursor-pointer font-medium text-ink-800 list-none flex justify-between items-center">
            {f.q}<span class="text-bronze-600 group-open:rotate-45 transition">+</span>
          </summary>
          <p class="mt-3 text-sm text-ink-700 leading-relaxed">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org', '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  })} />
</Base>
