---
import Shell from '../../layouts/Shell.astro';
import { getCategories } from '../../lib/queries';
const categories = await getCategories();
---
<Shell title="Collections | DigitalChiselCo" scrollPastBanner={true}>
  <h1 class="text-3xl mb-6">Shop by collection</h1>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {categories.map((c) => (
      <a href={`/collections/${c.slug}`} class="block border border-black/10 rounded-lg overflow-hidden hover:shadow-md transition group">
        <div class="aspect-[16/9] bg-cream overflow-hidden">
          {c.image_url
            ? <img src={c.image_url} alt={c.name} loading="lazy" class="w-full h-full object-cover group-hover:scale-[1.03] transition" />
            : <div class="w-full h-full flex items-center justify-center text-bronze-600/50 font-serif text-lg px-4 text-center">{c.name}</div>}
        </div>
        {!c.image_url && <div class="p-3 text-sm">{c.name}</div>}
      </a>
    ))}
  </div>
</Shell>
