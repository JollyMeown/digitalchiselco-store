---
import Shell from '../../layouts/Shell.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCategoryBySlug, getProductsByCategory, getSettings } from '../../lib/queries';

const { slug } = Astro.params;
const category = await getCategoryBySlug(slug!);
if (!category) return Astro.redirect('/collections');

const page = Math.max(1, Number(Astro.url.searchParams.get('page') || '1'));
const { products, total, perPage } = await getProductsByCategory(category.id, page);
const pages = Math.ceil(total / perPage);
const meta = (category.description || '').slice(0, 155) || `Browse ${total} ${category.name} bas-relief STL files for CNC, 3D printing and laser engraving.`;
const isPremium = category.slug === 'premium-bundle-offer';
const settings = await getSettings();
---
<Shell title={`${category.name} STL Files | DigitalChiselCo`} description={meta} scrollPastBanner={true}>
  <Breadcrumbs crumbs={[{ label: 'Collections', href: '/collections' }, { label: category.name }]} />
  {category.image_url ? (
    <>
      <div class="mb-5 overflow-hidden rounded-lg">
        <img src={category.image_url} alt={category.name} class="w-full h-auto block" loading="eager" />
      </div>
      <h1 class="sr-only">{category.name}</h1>
      {!isPremium && (
        <>
          <p class="text-ink-700/70 text-sm mb-6">{total.toLocaleString()} designs</p>
          {category.description && <p class="text-ink-700/80 text-sm mb-6 max-w-3xl">{category.description}</p>}
        </>
      )}
    </>
  ) : isPremium ? (
    <section class="mb-6 sm:mb-8 -mx-4 sm:-mx-6 px-5 sm:px-6 py-7 sm:py-10 bg-gradient-to-br from-[#FAEEDA] via-[#fbf4e6] to-[#FAC775]/40 rounded-2xl border border-[#FAC775]/30">
      <div class="text-[11px] tracking-[0.18em] uppercase text-bronze-700/80 font-medium mb-2">🔥 Limited-time savings</div>
      <h1 class="font-serif text-2xl sm:text-3xl md:text-4xl text-bronze-800 leading-tight">{category.name}</h1>
      <p class="text-xs sm:text-sm text-bronze-700/90 mt-1">{total.toLocaleString()} curated bundles · save more, carve more</p>
      {category.description && (
        <p class="mt-3 sm:mt-4 max-w-3xl text-sm md:text-[15px] text-ink-800 leading-relaxed">{category.description}</p>
      )}
    </section>
  ) : (
    <>
      <h1 class="text-3xl mb-1">{category.name}</h1>
      <p class="text-ink-700/70 text-sm mb-6">{total.toLocaleString()} designs</p>
      {category.description && <p class="text-ink-700/80 text-sm mb-6 max-w-3xl">{category.description}</p>}
    </>
  )}
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
    {products.map((p) => <ProductCard product={p} discount={settings.discount_percent} />)}
  </div>
  {pages > 1 && (
    <nav class="flex justify-center gap-2 mt-10 text-sm">
      {page > 1 && <a href={`/collections/${slug}?page=${page - 1}`} class="px-3 py-1.5 border border-black/10 rounded">← Prev</a>}
      <span class="px-3 py-1.5">Page {page} of {pages}</span>
      {page < pages && <a href={`/collections/${slug}?page=${page + 1}`} class="px-3 py-1.5 border border-black/10 rounded">Next →</a>}
    </nav>
  )}
</Shell>
