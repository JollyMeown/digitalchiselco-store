---
// Cart deliberately does NOT use the Shell (no left menu) — focused checkout view.
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { pricing } from '../lib/pricing';
const { percent } = pricing(1);
const paddleEnv = (import.meta.env.PADDLE_ENV === 'production' ? 'production' : 'sandbox');
const paddleToken = import.meta.env.PUBLIC_PADDLE_CLIENT_TOKEN || '';
---
<Base title="Cart | DigitalChiselCo">
  <Header />
  <Breadcrumbs crumbs={[{ label: 'Cart' }]} />
  <main class="px-6 pb-6 max-w-3xl mx-auto min-h-[40vh]">
    <h1 class="text-3xl mb-6">Your cart</h1>
    <div id="empty" class="text-ink-700/70 hidden">Your cart is empty. <a href="/catalog" class="text-bronze-600">Browse the catalog →</a></div>
    <div id="items" class="divide-y divide-black/10"></div>
    <div id="summary" class="mt-6 hidden">
      <div class="flex justify-between text-sm text-ink-700/60"><span>Subtotal</span><span id="subtotal">$0.00</span></div>
      <div class="flex justify-between text-sm text-green-700"><span>Discount ({percent}% off)</span><span id="savings">$0.00</span></div>
      <div class="flex justify-between text-lg font-medium mt-1"><span>Total</span><span id="total">$0.00</span></div>
      <button id="checkout" class="mt-4 w-full bg-bronze-600 text-cream py-3 rounded-md hover:bg-bronze-700 transition">Checkout</button>
      <p class="text-xs text-ink-700/60 mt-2 text-center">Secure checkout · instant download links emailed after purchase</p>
    </div>
  </main>

  <!-- Relevant-to-cart upsell (filled by JS using /api/related) -->
  <section id="upsell-wrap" class="px-6 pb-14 max-w-6xl mx-auto hidden">
    <h2 id="upsell-title" class="text-xl mb-1">You may also like</h2>
    <p class="text-sm text-ink-700/60 mb-4">Picked from the same collections as items in your cart.</p>
    <div id="upsell" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"></div>
  </section>

  <Footer />
  <!-- Paddle.js — overlay checkout -->
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <script is:inline define:vars={{ DISCOUNT: percent, PADDLE_TOKEN: paddleToken, PADDLE_ENV: paddleEnv }}>
    const fmt = (n) => '$' + Number(n).toFixed(2);
    const itemsEl = document.getElementById('items');
    const escAttr = (s) => String(s ?? '').replace(/"/g, '&quot;').replace(/</g, '&lt;');

    function renderCart() {
      const c = JSON.parse(localStorage.getItem('cart') || '[]');
      document.getElementById('empty').classList.toggle('hidden', c.length > 0);
      document.getElementById('summary').classList.toggle('hidden', c.length === 0);
      itemsEl.innerHTML = c.map((x) => `
        <div class="flex items-center gap-4 py-4">
          <div class="w-16 h-16 bg-cream rounded overflow-hidden flex-shrink-0">${x.img ? `<img src="${escAttr(x.img)}" class="w-full h-full object-cover">` : ''}</div>
          <a href="/product/${escAttr(x.slug)}" class="flex-1 text-sm">${escAttr(x.title)}</a>
          <span class="text-sm">${fmt(x.price)}</span>
          <button data-id="${escAttr(x.id)}" class="rm text-ink-700/50 hover:text-red-600">✕</button>
        </div>`).join('');
      const subtotalRaw = c.reduce((s, x) => s + Number(x.price), 0);
      // The store-wide discount is baked in: shown price IS the discounted price.
      // So the "original" total = price / (1 - d/100); savings = original − total.
      const original = subtotalRaw / (1 - DISCOUNT / 100);
      const savings = original - subtotalRaw;
      document.getElementById('subtotal').textContent = fmt(original);
      document.getElementById('savings').textContent = '−' + fmt(savings);
      document.getElementById('total').textContent = fmt(subtotalRaw);
      document.querySelectorAll('.rm').forEach((b) => b.addEventListener('click', () => {
        const next = JSON.parse(localStorage.getItem('cart') || '[]').filter((y) => y.id !== b.dataset.id);
        localStorage.setItem('cart', JSON.stringify(next)); window.dispatchEvent(new Event('cart-changed'));
        renderCart(); loadUpsell();
      }));
    }

    function cardHtml(p) {
      const original = (Number(p.price_usd) / (1 - DISCOUNT / 100)).toFixed(2);
      return `
        <div class="border border-black/10 rounded-md overflow-hidden hover:shadow transition flex flex-col">
          <a href="/product/${escAttr(p.slug)}" class="block aspect-square bg-cream overflow-hidden">
            ${p.image_url ? `<img src="${escAttr(p.image_url)}" alt="${escAttr(p.title)}" loading="lazy" class="w-full h-full object-cover">` : ''}
          </a>
          <div class="p-3 flex flex-col flex-1">
            <a href="/product/${escAttr(p.slug)}" class="text-sm leading-snug text-ink-800 line-clamp-2 min-h-[2.5em]">${escAttr(p.title.split('|')[0].trim())}</a>
            <div class="mt-1 flex items-center gap-2">
              <span class="text-bronze-600 text-sm font-medium">${fmt(p.price_usd)}</span>
              <span class="text-ink-700/40 text-xs line-through">$${original}</span>
            </div>
            <button class="add-to-cart mt-2 w-full text-xs border border-bronze-600 text-bronze-700 py-1.5 rounded hover:bg-bronze-600 hover:text-cream transition"
              data-id="${escAttr(p.id)}" data-slug="${escAttr(p.slug)}" data-title="${escAttr(p.title.split('|')[0].trim())}" data-price="${Number(p.price_usd)}" data-img="${escAttr(p.image_url || '')}">Add to cart</button>
          </div>
        </div>`;
    }

    async function loadUpsell() {
      const c = JSON.parse(localStorage.getItem('cart') || '[]');
      const ids = c.map((x) => x.id);
      try {
        const res = await fetch('/api/related', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ ids }) });
        const data = await res.json();
        const wrap = document.getElementById('upsell-wrap');
        const grid = document.getElementById('upsell');
        const title = document.getElementById('upsell-title');
        if (!data.products?.length) { wrap.classList.add('hidden'); return; }
        title.textContent = ids.length ? 'Complete your collection' : 'You may also like';
        grid.innerHTML = data.products.map(cardHtml).join('');
        wrap.classList.remove('hidden');
      } catch (e) { console.error('upsell load failed', e); }
    }

    renderCart();
    loadUpsell();
    window.addEventListener('cart-changed', () => { renderCart(); loadUpsell(); });

    // ── Paddle.js setup ────────────────────────────────────────────────
    function setupPaddle() {
      if (typeof Paddle === 'undefined' || !PADDLE_TOKEN) return false;
      try {
        if (PADDLE_ENV === 'sandbox') Paddle.Environment.set('sandbox');
        Paddle.Initialize({
          token: PADDLE_TOKEN,
          eventCallback: (e) => {
            if (e.name === 'checkout.completed') {
              const txnId = e.data?.transaction_id || e.data?.id;
              localStorage.setItem('cart', '[]');
              window.dispatchEvent(new Event('cart-changed'));
              window.location.href = '/checkout/success' + (txnId ? '?txn=' + encodeURIComponent(txnId) : '');
            } else if (e.name === 'checkout.error') {
              console.error('Paddle checkout error:', e);
            }
          },
        });
      } catch (err) {
        console.error('Paddle setup failed:', err);
        return false;
      }
      return true;
    }

    // Wait for Paddle.js to attach
    function whenPaddleReady(cb) {
      if (typeof Paddle !== 'undefined') return cb();
      let tries = 0;
      const t = setInterval(() => {
        if (typeof Paddle !== 'undefined') { clearInterval(t); cb(); }
        else if (++tries > 50) { clearInterval(t); console.error('Paddle.js failed to load.'); }
      }, 100);
    }

    whenPaddleReady(setupPaddle);

    document.getElementById('checkout')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget;
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      if (!cart.length) return;
      if (!PADDLE_TOKEN) { alert('Checkout is not yet configured. Please contact support.'); return; }
      btn.disabled = true; btn.textContent = 'Starting checkout…';
      try {
        const res = await fetch('/api/checkout-init', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ items: cart, discount_percent: DISCOUNT }),
        });
        const data = await res.json();
        if (!res.ok || !data.transaction_id) throw new Error(data.error || 'Could not start checkout.');
        Paddle.Checkout.open({ transactionId: data.transaction_id });
        btn.disabled = false; btn.textContent = 'Checkout';
      } catch (err) {
        console.error(err);
        alert(err.message || 'Checkout failed. Please try again.');
        btn.disabled = false; btn.textContent = 'Checkout';
      }
    });
  </script>
</Base>
