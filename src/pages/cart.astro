---
// Cart deliberately does NOT use the Shell (no left menu) — focused checkout view.
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { pricing } from '../lib/pricing';
import { getSettings } from '../lib/queries';
const { percent } = pricing(1);
const settings = await getSettings();
const showCartPromos = (settings as any).cart_promos_active !== false;
const promoTiers = [
  { items: 6, percent: 15, code: '2026OFF15' },
  { items: 10, percent: 20, code: '2026OFF20' },
  { items: 25, percent: 35, code: '2026OFF35' },
];
const paddleEnv = (import.meta.env.PADDLE_ENV === 'production' ? 'production' : 'sandbox');
const paddleToken = import.meta.env.PUBLIC_PADDLE_CLIENT_TOKEN || '';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---
<Base title="Cart | DigitalChiselCo">
  <Header />
  <Breadcrumbs crumbs={[{ label: 'Cart' }]} />
  <main class="px-6 pb-6 max-w-3xl mx-auto min-h-[40vh]">
    <h1 class="text-3xl mb-6">Your cart</h1>
    {showCartPromos && (
      <div class="mb-6 rounded-lg border border-bronze-600/30 bg-[#FAEEDA] px-4 py-3">
        <p class="text-sm font-medium text-bronze-800">Save more when you buy more on my 3D models 🎉</p>
        <ul class="mt-2 space-y-1.5 text-sm text-ink-800">
          {promoTiers.map((t) => (
            <li class="flex items-center gap-2 flex-wrap">
              <span class="text-green-700" aria-hidden="true">☑</span>
              <span>{t.items} items → <strong>{t.percent}% OFF</strong></span>
              <code class="sm:ml-auto font-mono text-xs bg-white/70 border border-bronze-600/20 rounded px-2 py-0.5 text-bronze-800">{t.code}</code>
            </li>
          ))}
        </ul>
      </div>
    )}
    <div id="empty" class="text-ink-700/70 hidden">Your cart is empty. <a href="/catalog" class="text-bronze-600">Browse the catalog →</a></div>
    <div id="items" class="divide-y divide-black/10"></div>
    <div id="summary" class="mt-6 hidden">
      <!-- Bulk discount upsell hint — appears only when adding more items unlocks a deeper discount -->
      <div id="tier-hint" class="hidden mb-4 bg-[#FAEEDA] border border-bronze-600/30 rounded-md px-3 py-2.5 text-sm text-bronze-800 flex flex-col sm:flex-row sm:items-center justify-between gap-2 sm:gap-3">
        <span id="tier-hint-text" class="leading-snug">Add more items to unlock a bigger discount.</span>
        <a href="/catalog" class="flex-shrink-0 text-xs font-medium text-bronze-700 underline whitespace-nowrap self-start sm:self-auto">Add items →</a>
      </div>
      <div class="flex justify-between text-sm text-ink-700/60"><span>Subtotal</span><span id="subtotal">$0.00</span></div>
      <div class="flex justify-between text-sm text-green-700"><span>Discount ({percent}% off)</span><span id="savings">$0.00</span></div>

      <!-- Promo code -->
      <div class="mt-4 border-t border-black/10 pt-4">
        <details class="group">
          <summary class="cursor-pointer text-sm text-bronze-700 hover:underline list-none select-none flex items-center gap-1">
            <span class="group-open:rotate-90 inline-block transition">▸</span> Have a promo code?
          </summary>
          <div class="mt-3 flex gap-2">
            <input id="promo-code" type="text" autocapitalize="characters" placeholder="e.g. 2026OFF15"
              class="flex-1 px-3 py-2 text-sm border border-black/15 rounded-md font-mono uppercase tracking-wider focus:outline-none focus:border-bronze-600" />
            <button id="promo-apply" type="button" class="px-4 py-2 text-sm bg-bronze-600 text-cream rounded-md hover:bg-bronze-700 transition">Apply</button>
            <button id="promo-remove" type="button" class="hidden px-3 py-2 text-sm border border-black/15 rounded-md hover:bg-cream">Remove</button>
          </div>
          <p id="promo-msg" class="mt-2 text-xs"></p>
        </details>
        <div id="promo-row" class="hidden flex justify-between text-sm text-green-700 mt-2"><span id="promo-label">Promo</span><span id="promo-amount">$0.00</span></div>
      </div>

      <div class="flex justify-between text-lg font-medium mt-3 border-t border-black/10 pt-3"><span>Total</span><span id="total">$0.00</span></div>

      <!-- Email at cart — lets us pre-lock Paddle's email field so the receipt
           goes to exactly the address the buyer enters here. -->
      <div class="mt-4">
        <label for="buyer-email" class="block text-xs text-ink-700/70 mb-1">Email for download links and receipt</label>
        <input id="buyer-email" type="email" inputmode="email" autocomplete="email" required placeholder="you@email.com"
          class="w-full px-3 py-2 text-sm border border-black/15 rounded-md focus:outline-none focus:border-bronze-600 bg-white" />
        <p id="buyer-email-msg" class="mt-1 text-xs text-red-600 hidden"></p>
        <p class="mt-1 text-[11px] text-ink-700/50">We send your STL files and receipt here. This is the same email you'll see in the payment popup.</p>
      </div>

      <button id="checkout" class="mt-4 w-full bg-bronze-600 text-cream py-3 rounded-md hover:bg-bronze-700 transition">Checkout</button>
      <p class="text-xs text-ink-700/60 mt-2 text-center">Secure checkout · instant download links emailed after purchase</p>
    </div>
  </main>

  <!-- Relevant-to-cart upsell (filled by JS using /api/related) -->
  <section id="upsell-wrap" class="px-6 pb-14 max-w-6xl mx-auto hidden">
    <h2 id="upsell-title" class="text-xl mb-1">You may also like</h2>
    <p class="text-sm text-ink-700/60 mb-4">Picked from the same collections as items in your cart.</p>
    <div id="upsell" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4"></div>
  </section>

  <Footer />
  <!-- Paddle.js — overlay checkout -->
  <script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <script is:inline define:vars={{ DISCOUNT: percent, PADDLE_TOKEN: paddleToken, PADDLE_ENV: paddleEnv, SUPABASE_URL: supabaseUrl, SUPABASE_ANON_KEY: supabaseAnonKey }}>
    const fmt = (n) => '$' + Number(n).toFixed(2);
    const itemsEl = document.getElementById('items');
    const escAttr = (s) => String(s ?? '').replace(/"/g, '&quot;').replace(/</g, '&lt;');

    // Customization fields keyed by product_id, fetched once per render
    let customFieldsByProduct = {};

    function renderCart() {
      const c = JSON.parse(localStorage.getItem('cart') || '[]');
      document.getElementById('empty').classList.toggle('hidden', c.length > 0);
      document.getElementById('summary').classList.toggle('hidden', c.length === 0);
      itemsEl.innerHTML = c.map((x, idx) => {
        const fields = customFieldsByProduct[x.id] || [];
        const fieldsHtml = fields.length ? renderCustomFieldsBlock(x, fields, idx) : '';
        return `
        <div class="py-4">
          <div class="flex items-center gap-4">
            <div class="w-16 h-16 bg-cream rounded overflow-hidden flex-shrink-0">${x.img ? `<img src="${escAttr(x.img)}" class="w-full h-full object-cover">` : ''}</div>
            <a href="/product/${escAttr(x.slug)}" class="flex-1 text-sm">${escAttr(x.title)}</a>
            <span class="text-sm">${fmt(x.price)}</span>
            <button data-id="${escAttr(x.id)}" class="rm text-ink-700/50 hover:text-red-600">✕</button>
          </div>
          ${fieldsHtml}
        </div>`;
      }).join('');
      wireCustomFieldInputs();
      const subtotalRaw = c.reduce((s, x) => s + Number(x.price), 0);
      // The store-wide discount is baked in: shown price IS the discounted price.
      // So the "original" total = price / (1 - d/100); savings = original − total.
      const original = subtotalRaw / (1 - DISCOUNT / 100);
      const savings = original - subtotalRaw;
      document.getElementById('subtotal').textContent = fmt(original);
      document.getElementById('savings').textContent = '−' + fmt(savings);
      const promo = JSON.parse(localStorage.getItem('promo') || 'null');
      const promoOff = promo?.discount_amount ? Math.min(subtotalRaw, Number(promo.discount_amount)) : 0;
      document.getElementById('total').textContent = fmt(Math.max(0, subtotalRaw - promoOff));
      const promoRow = document.getElementById('promo-row');
      const promoLabel = document.getElementById('promo-label');
      const promoAmount = document.getElementById('promo-amount');
      const promoRemove = document.getElementById('promo-remove');
      if (promo?.code && promoOff > 0) {
        promoRow.classList.remove('hidden');
        promoLabel.textContent = 'Promo (' + promo.code + ')';
        promoAmount.textContent = '−' + fmt(promoOff);
        promoRemove?.classList.remove('hidden');
      } else {
        promoRow.classList.add('hidden');
        promoRemove?.classList.add('hidden');
      }

      // Re-validate the applied promo against the live cart on every change.
      // Without this, removing items below a tier's minimum (e.g. 6 items for
      // 2026OFF15) would leave the discount applied stale. Debounced via a
      // simple in-flight flag so rapid cart edits collapse into one round-trip.
      revalidatePromoSoon(c, promo);

      // ── Bulk-discount upsell hint ─────────────────────────────────
      // Tiers must mirror seed_bulk_promos.mjs. Find the next tier the
      // cart hasn't reached and tell the customer how to unlock it.
      const tiers = [
        { items: 6,  percent: 15, code: '2026OFF15' },
        { items: 10, percent: 20, code: '2026OFF20' },
        { items: 25, percent: 35, code: '2026OFF35' },
      ];
      const itemCount = c.length;
      const hintBox = document.getElementById('tier-hint');
      const hintText = document.getElementById('tier-hint-text');
      const next = tiers.find((t) => t.items > itemCount);
      if (next && itemCount > 0) {
        const diff = next.items - itemCount;
        hintText.innerHTML = '🔥 Add ' + diff + ' more item' + (diff === 1 ? '' : 's') + ' to unlock <strong>' + next.percent + '% OFF</strong> with code <code class="font-mono">' + next.code + '</code>';
        hintBox.classList.remove('hidden');
      } else if (itemCount > 0 && tiers.length) {
        const reached = tiers.filter((t) => t.items <= itemCount).pop();
        if (reached && (!promo || promo.code !== reached.code)) {
          hintText.innerHTML = '✓ You qualify for <strong>' + reached.percent + '% OFF</strong> — apply code <code class="font-mono">' + reached.code + '</code> below.';
          hintBox.classList.remove('hidden');
        } else {
          hintBox.classList.add('hidden');
        }
      } else {
        hintBox.classList.add('hidden');
      }
      document.querySelectorAll('.rm').forEach((b) => b.addEventListener('click', () => {
        const next = JSON.parse(localStorage.getItem('cart') || '[]').filter((y) => y.id !== b.dataset.id);
        localStorage.setItem('cart', JSON.stringify(next)); window.dispatchEvent(new Event('cart-changed'));
        renderCart(); loadUpsell();
      }));
    }

    function cardHtml(p) {
      const original = (Number(p.price_usd) / (1 - DISCOUNT / 100)).toFixed(2);
      return `
        <div class="border border-black/10 rounded-md overflow-hidden hover:shadow transition flex flex-col">
          <a href="/product/${escAttr(p.slug)}" class="block aspect-square bg-cream overflow-hidden">
            ${p.image_url ? `<img src="${escAttr(p.image_url)}" alt="${escAttr(p.title)}" loading="lazy" class="w-full h-full object-cover">` : ''}
          </a>
          <div class="p-3 flex flex-col flex-1">
            <a href="/product/${escAttr(p.slug)}" class="text-sm leading-snug text-ink-800 line-clamp-2 min-h-[2.5em]">${escAttr(p.title.split('|')[0].trim())}</a>
            <div class="mt-1 flex items-center gap-2">
              <span class="text-bronze-600 text-sm font-medium">${fmt(p.price_usd)}</span>
              <span class="text-ink-700/40 text-xs line-through">$${original}</span>
            </div>
            <button class="add-to-cart mt-2 w-full text-xs border border-bronze-600 text-bronze-700 py-1.5 rounded hover:bg-bronze-600 hover:text-cream transition"
              data-id="${escAttr(p.id)}" data-slug="${escAttr(p.slug)}" data-title="${escAttr(p.title.split('|')[0].trim())}" data-price="${Number(p.price_usd)}" data-img="${escAttr(p.image_url || '')}">Add to cart</button>
          </div>
        </div>`;
    }

    async function loadUpsell() {
      const c = JSON.parse(localStorage.getItem('cart') || '[]');
      const ids = c.map((x) => x.id);
      try {
        const res = await fetch('/api/related', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ ids }) });
        const data = await res.json();
        const wrap = document.getElementById('upsell-wrap');
        const grid = document.getElementById('upsell');
        const title = document.getElementById('upsell-title');
        if (!data.products?.length) { wrap.classList.add('hidden'); return; }
        title.textContent = ids.length ? 'Complete your collection' : 'You may also like';
        grid.innerHTML = data.products.map(cardHtml).join('');
        wrap.classList.remove('hidden');
        window.dccSyncCartButtons?.(); // reflect in-cart state on upsell cards
      } catch (e) { console.error('upsell load failed', e); }
    }

    // Tiny debouncing wrapper used by renderCart() to re-check the applied
    // promo against the live cart whenever items change.
    let revalTimer = null;
    let revalInFlight = false;
    let lastCartHash = '';
    async function revalidatePromoSoon(c, promo) {
      if (!promo?.code) { lastCartHash = JSON.stringify(c.map((x) => x.id).sort()); return; }
      const hash = JSON.stringify(c.map((x) => x.id).sort());
      if (hash === lastCartHash && !revalInFlight) return; // nothing to do
      lastCartHash = hash;
      clearTimeout(revalTimer);
      revalTimer = setTimeout(() => doRevalidate(promo.code), 200);
    }
    async function doRevalidate(code) {
      if (revalInFlight) return;
      revalInFlight = true;
      try {
        const cart = JSON.parse(localStorage.getItem('cart') || '[]')
          .filter((c) => !String(c.id).startsWith('membership:'))
          .map((c) => ({ id: c.id, price: Number(c.price), qty: 1, title: c.title }));
        if (cart.length === 0) {
          localStorage.removeItem('promo');
          renderCart();
          return;
        }
        const res = await fetch('/api/coupons/validate', {
          method: 'POST', headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ code, items: cart }),
        });
        const data = await res.json();
        if (res.ok && data.ok) {
          // Update the stored discount so the next renderCart() uses the fresh number.
          localStorage.setItem('promo', JSON.stringify({
            code: data.code, description: data.description,
            discount_amount: data.discount_amount, percent_off: data.percent_off,
          }));
          const promoMsg = document.getElementById('promo-msg');
          if (promoMsg && promoMsg.textContent.startsWith('✕')) promoMsg.textContent = '';
          renderCart();
        } else {
          // Promo no longer eligible — drop it and tell the user gently.
          localStorage.removeItem('promo');
          const promoMsg = document.getElementById('promo-msg');
          if (promoMsg) {
            promoMsg.textContent = '⚠ Promo "' + code + '" removed — ' + (data.error || 'no longer eligible for this cart.');
            promoMsg.className = 'mt-2 text-xs text-amber-700';
          }
          renderCart();
        }
      } catch (e) {
        // Network blip — leave the promo in place; we'll re-check on next change.
      } finally {
        revalInFlight = false;
      }
    }

    // ── Customization fields fetcher ─────────────────────────────────
    // Public-read RLS allows direct Supabase REST query for the field definitions.
    async function loadCustomFields() {
      const c = JSON.parse(localStorage.getItem('cart') || '[]');
      const ids = [...new Set(c.map((x) => x.id).filter((id) => id && !String(id).startsWith('membership:')))];
      if (!ids.length) { customFieldsByProduct = {}; return; }
      try {
        const url = SUPABASE_URL + '/rest/v1/product_custom_fields?select=*&product_id=in.(' + ids.join(',') + ')&order=sort_order';
        const res = await fetch(url, { headers: { apikey: SUPABASE_ANON_KEY, Authorization: 'Bearer ' + SUPABASE_ANON_KEY } });
        if (!res.ok) { customFieldsByProduct = {}; return; }
        const data = await res.json();
        const grouped = {};
        for (const f of data) { (grouped[f.product_id] = grouped[f.product_id] || []).push(f); }
        customFieldsByProduct = grouped;
      } catch (e) { console.error('loadCustomFields failed', e); customFieldsByProduct = {}; }
    }

    function renderCustomFieldsBlock(cartItem, fields, idx) {
      const stored = cartItem.customizations || {};
      const inputs = fields.map((f) => {
        const v = stored[f.field_key] ?? '';
        const ml = f.max_length ? ' maxlength="' + f.max_length + '"' : '';
        const req = f.required ? ' required' : '';
        const ph = f.placeholder ? ' placeholder="' + escAttr(f.placeholder) + '"' : '';
        const help = f.help_text ? '<p class="text-[11px] text-ink-700/50 mt-0.5">' + escAttr(f.help_text) + '</p>' : '';
        const req_mark = f.required ? '<span class="text-red-600">*</span>' : '';
        const cls = 'cf-input w-full px-2.5 py-1.5 text-sm border border-black/15 rounded focus:outline-none focus:border-bronze-600';
        let input;
        if (f.field_type === 'textarea') {
          input = '<textarea data-cart-idx="' + idx + '" data-key="' + escAttr(f.field_key) + '" rows="2" class="' + cls + '"' + ph + req + ml + '>' + escAttr(v) + '</textarea>';
        } else {
          const type = f.field_type === 'file_url' ? 'url' : f.field_type === 'phone' ? 'tel' : f.field_type;
          input = '<input data-cart-idx="' + idx + '" data-key="' + escAttr(f.field_key) + '" type="' + type + '" class="' + cls + '" value="' + escAttr(v) + '"' + ph + req + ml + '/>';
        }
        return '<label class="block"><span class="text-[11px] text-ink-700/70 block mb-0.5">' + escAttr(f.label) + ' ' + req_mark + '</span>' + input + help + '</label>';
      }).join('');
      return '<div class="mt-3 ml-20 p-3 rounded-md bg-bronze-50/40 border border-bronze-600/20 space-y-2"><div class="text-[11px] tracking-wider uppercase text-bronze-700/80 font-medium mb-1">✎ Personalize this item</div>' + inputs + '</div>';
    }

    function wireCustomFieldInputs() {
      document.querySelectorAll('[data-cart-idx]').forEach((el) => {
        el.addEventListener('input', () => {
          const idx = Number(el.dataset.cartIdx);
          const key = el.dataset.key;
          const c = JSON.parse(localStorage.getItem('cart') || '[]');
          if (!c[idx]) return;
          c[idx].customizations = c[idx].customizations || {};
          c[idx].customizations[key] = el.value;
          localStorage.setItem('cart', JSON.stringify(c));
        });
      });
    }

    async function refreshAll() {
      await loadCustomFields();
      renderCart();
    }

    refreshAll();
    loadUpsell();
    window.addEventListener('cart-changed', () => { refreshAll(); loadUpsell(); });

    // ── Buyer email persistence ───────────────────────────────────────
    // Remember the last email between visits so the field is pre-filled.
    const emailInput = document.getElementById('buyer-email');
    const emailMsg = document.getElementById('buyer-email-msg');
    try {
      const saved = localStorage.getItem('buyer_email');
      if (saved && emailInput) emailInput.value = saved;
    } catch {}
    emailInput?.addEventListener('input', () => {
      emailMsg.classList.add('hidden');
      try { localStorage.setItem('buyer_email', emailInput.value.trim()); } catch {}
    });

    // ── Promo code ────────────────────────────────────────────────────
    const promoMsg = document.getElementById('promo-msg');
    const promoCodeInput = document.getElementById('promo-code');
    // Pre-fill if already applied
    {
      const existing = JSON.parse(localStorage.getItem('promo') || 'null');
      if (existing?.code) { promoCodeInput.value = existing.code; promoMsg.textContent = '✓ ' + (existing.description || existing.code) + ' applied.'; promoMsg.className = 'mt-2 text-xs text-green-700'; }
    }
    document.getElementById('promo-apply')?.addEventListener('click', async () => {
      const code = (promoCodeInput.value || '').trim().toUpperCase();
      if (!code) { promoMsg.textContent = 'Enter a code.'; promoMsg.className = 'mt-2 text-xs text-red-600'; return; }
      const cart = JSON.parse(localStorage.getItem('cart') || '[]')
        .filter((c) => !String(c.id).startsWith('membership:'))
        .map((c) => ({ id: c.id, price: Number(c.price), qty: 1, title: c.title }));
      promoMsg.textContent = 'Checking…'; promoMsg.className = 'mt-2 text-xs text-ink-700/60';
      try {
        const res = await fetch('/api/coupons/validate', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ code, items: cart }) });
        const data = await res.json();
        if (!res.ok || !data.ok) { promoMsg.textContent = '✕ ' + (data.error || 'Code not valid.'); promoMsg.className = 'mt-2 text-xs text-red-600'; return; }
        localStorage.setItem('promo', JSON.stringify({ code: data.code, description: data.description, discount_amount: data.discount_amount, percent_off: data.percent_off }));
        promoMsg.textContent = '✓ ' + (data.description || data.code) + ' applied — saved ' + fmt(data.discount_amount);
        promoMsg.className = 'mt-2 text-xs text-green-700';
        // Pretend the cart "changed" so the revalidator's hash is up to date
        lastCartHash = JSON.stringify(JSON.parse(localStorage.getItem('cart') || '[]').map((x) => x.id).sort());
        renderCart();
      } catch (e) {
        promoMsg.textContent = 'Network error. Please try again.'; promoMsg.className = 'mt-2 text-xs text-red-600';
      }
    });
    document.getElementById('promo-remove')?.addEventListener('click', () => {
      localStorage.removeItem('promo'); promoCodeInput.value = ''; promoMsg.textContent = ''; renderCart();
    });

    // ── Paddle.js setup ────────────────────────────────────────────────
    function setupPaddle() {
      if (typeof Paddle === 'undefined' || !PADDLE_TOKEN) return false;
      try {
        if (PADDLE_ENV === 'sandbox') Paddle.Environment.set('sandbox');
        Paddle.Initialize({
          token: PADDLE_TOKEN,
          eventCallback: (e) => {
            if (e.name === 'checkout.completed') {
              const txnId = e.data?.transaction_id || e.data?.id;
              localStorage.setItem('cart', '[]');
              window.dispatchEvent(new Event('cart-changed'));
              window.location.href = '/checkout/success' + (txnId ? '?txn=' + encodeURIComponent(txnId) : '');
            } else if (e.name === 'checkout.error') {
              console.error('Paddle checkout error:', e);
            }
          },
        });
      } catch (err) {
        console.error('Paddle setup failed:', err);
        return false;
      }
      return true;
    }

    // Wait for Paddle.js to attach
    function whenPaddleReady(cb) {
      if (typeof Paddle !== 'undefined') return cb();
      let tries = 0;
      const t = setInterval(() => {
        if (typeof Paddle !== 'undefined') { clearInterval(t); cb(); }
        else if (++tries > 50) { clearInterval(t); console.error('Paddle.js failed to load.'); }
      }, 100);
    }

    whenPaddleReady(setupPaddle);

    document.getElementById('checkout')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget;
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      if (!cart.length) return;
      if (!PADDLE_TOKEN) { alert('Checkout is not yet configured. Please contact support.'); return; }

      // Require + validate email before opening Paddle, so the receipt and
      // download links land exactly where the buyer expects.
      const buyerEmail = (emailInput?.value || '').trim().toLowerCase();
      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(buyerEmail)) {
        emailMsg.textContent = 'Please enter a valid email — we send your downloads here.';
        emailMsg.classList.remove('hidden');
        emailInput?.focus();
        return;
      }
      try { localStorage.setItem('buyer_email', buyerEmail); } catch {}

      // Validate any required customization fields on customizable items.
      // Walks the rendered inputs (which the user has been editing) and uses
      // native form validity so empty required fields, bad emails, bad URLs etc.
      // all surface with the browser's own error UI.
      const cfInputs = Array.from(document.querySelectorAll('[data-cart-idx]'));
      for (const el of cfInputs) {
        if (!el.checkValidity()) {
          el.reportValidity();
          el.focus();
          return;
        }
      }
      // Stamp final customizations into cart from inputs (in case any input event hadn't fired)
      cfInputs.forEach((el) => {
        const idx = Number(el.dataset.cartIdx);
        const key = el.dataset.key;
        if (!cart[idx]) return;
        cart[idx].customizations = cart[idx].customizations || {};
        cart[idx].customizations[key] = el.value;
      });
      localStorage.setItem('cart', JSON.stringify(cart));

      // Build a customization payload keyed by cart-line index, preserving
      // label/type so the order display survives admin field edits later.
      const customizationsPayload = cart.map((it) => {
        const fields = customFieldsByProduct[it.id] || [];
        if (!fields.length) return null;
        const vals = it.customizations || {};
        return fields.map((f) => ({ key: f.field_key, label: f.label, type: f.field_type, value: vals[f.field_key] || '' }));
      });

      btn.disabled = true; btn.textContent = 'Starting checkout…';
      try {
        const promo = JSON.parse(localStorage.getItem('promo') || 'null');
        const res = await fetch('/api/checkout-init', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ items: cart, email: buyerEmail, discount_percent: DISCOUNT, coupon_code: promo?.code || null, customizations: customizationsPayload }),
        });
        const data = await res.json();
        if (!res.ok || !data.transaction_id) throw new Error(data.error || 'Could not start checkout.');
        // Passing customer.email here pre-fills + locks the email field in
        // Paddle's overlay, so the receipt can only go to the same address
        // we already captured.
        Paddle.Checkout.open({
          transactionId: data.transaction_id,
          customer: { email: buyerEmail },
        });
        btn.disabled = false; btn.textContent = 'Checkout';
      } catch (err) {
        console.error(err);
        alert(err.message || 'Checkout failed. Please try again.');
        btn.disabled = false; btn.textContent = 'Checkout';
      }
    });
  </script>
</Base>
