---
import Shell from '../layouts/Shell.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getMembershipPlans } from '../lib/queries';
const plans = await getMembershipPlans();
const featured = plans.find((p) => p.highlight) || plans[0];
---
<Shell title="Become a Member · DigitalChiselCo" description="CNC STL membership — 8 fresh bas-relief STL designs every month, 24 carving files for $20. Instant first pack, commercial use, no recurring charge." scrollPastBanner={true}>
  <Breadcrumbs crumbs={[{ label: 'Membership' }]} />

  <!-- HERO -->
  <section class="mb-10">
    <p class="text-xs tracking-widest text-bronze-600 mb-3">★ DIGITALCHISELCO MEMBERSHIP</p>
    <h1 class="font-serif text-3xl md:text-5xl text-bronze-800 leading-tight max-w-3xl">
      🔥 Stop wasting your weekends searching for CNC files.
    </h1>
    <p class="mt-4 text-lg text-ink-700 max-w-2xl leading-relaxed">
      Your next 3 months of carving projects are already waiting. Get a premium 3-Month CNC STL Membership with <strong>8 fresh bas-relief STL designs delivered every month</strong> — 24 total carving files for only <span class="text-bronze-700 font-semibold">$20</span>.
    </p>
    <p class="mt-2 text-bronze-700">That's roughly <strong>$192 worth of CNC STL files for just $20</strong> — about <strong>90% off retail</strong>. ✅</p>
  </section>

  <!-- PLAN PICKER -->
  <section id="plans" class="mb-12">
    <h2 class="font-serif text-2xl mb-5">Pick your plan</h2>
    <div class="grid md:grid-cols-2 gap-5">
      {plans.map((p) => (
        <label class={`plan-card cursor-pointer block border-2 rounded-xl p-6 transition ${p.highlight ? 'border-bronze-600 bg-cream/40' : 'border-black/10 bg-white hover:border-bronze-600/60'}`} data-slug={p.slug} data-name={p.name} data-price={p.price_usd}>
          <div class="flex justify-between items-start mb-3">
            <div>
              <input type="radio" name="plan" value={p.slug} checked={p.highlight} class="mr-2 plan-radio" />
              <span class="font-medium text-lg text-ink-800">{p.name}</span>
              {p.highlight && <span class="ml-2 text-xs bg-bronze-600 text-cream px-2 py-0.5 rounded">★ MOST POPULAR</span>}
            </div>
            <div class="text-right">
              <div class="font-serif text-3xl text-bronze-700">${Number(p.price_usd).toFixed(2)}</div>
              {p.original_price_usd && <div class="text-xs text-ink-700/40 line-through">${Number(p.original_price_usd).toFixed(2)} value</div>}
            </div>
          </div>
          <ul class="text-sm text-ink-700 space-y-1.5 mt-3">
            {p.features.map((f) => <li class="flex gap-2"><span class="text-bronze-600">✓</span>{f}</li>)}
          </ul>
        </label>
      ))}
    </div>
  </section>

  <!-- SIGN-UP FORM -->
  <section class="mb-14 border border-black/10 rounded-xl p-6 md:p-8 bg-cream/30">
    <h2 class="font-serif text-2xl mb-1">Reserve your spot</h2>
    <p class="text-sm text-ink-700/70 mb-5">Tell us where to send your first 8-file pack.</p>
    <form id="member-form" class="grid sm:grid-cols-2 gap-3 max-w-xl">
      <div>
        <label class="text-xs block mb-1 font-medium" for="m-name">Name</label>
        <input id="m-name" required type="text" placeholder="Your name" class="w-full px-4 py-3 rounded-md border border-bronze-600/30 focus:outline-none focus:border-bronze-600 bg-white" />
      </div>
      <div>
        <label class="text-xs block mb-1 font-medium" for="m-email">Email</label>
        <input id="m-email" required type="email" placeholder="you@email.com" class="w-full px-4 py-3 rounded-md border border-bronze-600/30 focus:outline-none focus:border-bronze-600 bg-white" />
      </div>
      <div class="sm:col-span-2 flex flex-wrap gap-3 mt-2">
        <button type="submit" data-action="add" class="bg-bronze-600 text-cream px-6 py-3 rounded-md text-sm hover:bg-bronze-700 transition shadow-sm">Add to cart →</button>
        <button type="submit" data-action="checkout" class="border border-bronze-600 text-bronze-700 px-6 py-3 rounded-md text-sm hover:bg-bronze-600/10 transition">Add &amp; checkout now →</button>
      </div>
      <p id="m-msg" class="sm:col-span-2 text-sm hidden"></p>
    </form>
    <p class="text-xs text-ink-700/50 mt-3">One $20 order covers the full 3 months. No recurring charge. No surprise payment later.</p>
  </section>

  <!-- WHY -->
  <section class="mb-14 grid md:grid-cols-2 gap-10">
    <div>
      <h2 class="font-serif text-2xl mb-3">✨ Why this membership is a smart buy</h2>
      <p class="text-ink-700 leading-relaxed">You get new CNC-ready designs without searching, guessing, or buying files one by one. Your first pack starts right away, and a new themed set arrives each month for 3 months.</p>
    </div>
    <div class="border border-bronze-600/20 rounded-lg p-5 bg-cream/40">
      <h3 class="font-medium text-bronze-700 mb-3">⭐ The math</h3>
      <ul class="text-sm text-ink-700 space-y-1.5">
        <li>• 8 files per month</li>
        <li>• 24 total STL files over 3 months</li>
        <li>• Around $64 value every month</li>
        <li>• Roughly $192 total retail value</li>
        <li>• Your price: <strong>only $20</strong></li>
        <li>• About 90% off retail</li>
      </ul>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="mb-14">
    <h2 class="font-serif text-2xl mb-4">🚀 How it works — instant start</h2>
    <p class="text-ink-700 leading-relaxed">Order today and receive your first 8 bas-relief STL files within minutes through your member access link / welcome email.</p>
    <ul class="mt-4 text-sm text-ink-700 space-y-1.5">
      <li>✓ No waiting for a billing cycle</li>
      <li>✓ No recurring charge</li>
      <li>✓ No surprise payment later</li>
      <li>✓ One $20 order covers the full 3 months</li>
    </ul>
  </section>

  <!-- WHAT YOU GET -->
  <section class="mb-14">
    <h2 class="font-serif text-2xl mb-4">📦 What you get each month</h2>
    <ul class="text-ink-700 space-y-2 leading-relaxed">
      <li>• 8 professionally finished bas-relief STL files</li>
      <li>• Fresh monthly themes such as wildlife, florals, patriotic, seasonal, rustic decor, animals, wall art, and more</li>
      <li>• CNC-ready STL files for VCarve, Aspire, Fusion 360, and compatible CAM software</li>
      <li>• Scalable designs to fit your material, router size, and project style</li>
      <li>• Perfect files for wall art, signs, plaques, gifts, craft fairs, and woodworking products</li>
    </ul>
  </section>

  <!-- PERFECT FOR YOU IF -->
  <section class="mb-14 grid md:grid-cols-2 gap-10">
    <div>
      <h2 class="font-serif text-2xl mb-3">🛠 Perfect for you if you</h2>
      <ul class="text-ink-700 space-y-1.5">
        <li>• Own a CNC router and want fresh designs every month</li>
        <li>• Want professional STL files without spending hours searching</li>
        <li>• Want to build a ready-to-carve project library</li>
        <li>• Want to test a short membership before committing longer</li>
        <li>• Love having a reason to fire up the router every month</li>
      </ul>
    </div>
    <div>
      <h2 class="font-serif text-2xl mb-3">📁 File format &amp; delivery</h2>
      <p class="text-ink-700 leading-relaxed">Files are delivered in <strong>.STL</strong> format — the standard format for CNC bas-relief carving.</p>
      <p class="mt-3 text-ink-700">Your first pack is available after checkout. The next 8-file packs arrive monthly for 3 months through your member access link.</p>
    </div>
  </section>

  <!-- LICENSE -->
  <section class="mb-14 border-l-4 border-bronze-600 bg-cream/40 p-5 rounded-r-lg">
    <h3 class="font-medium text-bronze-700 mb-2">✅ Commercial use included</h3>
    <p class="text-sm text-ink-700">You may sell the physical carved pieces you create from these files.</p>
    <p class="text-sm text-ink-700 mt-2"><strong>🚫 Not allowed:</strong> reselling, sharing, uploading, copying, or redistributing the digital STL files themselves.</p>
    <p class="text-sm text-ink-700 mt-2"><strong>⚠️ Digital download only.</strong> No physical item will be shipped. This listing is for digital CNC STL files only.</p>
  </section>

  <!-- FINAL CTA -->
  <section class="mb-12 text-center border border-bronze-600/30 rounded-xl p-8 bg-gradient-to-br from-cream to-white">
    <p class="font-serif text-2xl md:text-3xl text-bronze-800">👉 24 files. $192 value. Only $20.</p>
    <p class="mt-3 text-ink-700">Add to cart now — your first CNC carving pack is waiting.</p>
    <a href="#plans" class="mt-5 inline-block bg-bronze-600 text-cream px-8 py-3 rounded-md text-sm hover:bg-bronze-700 transition shadow">Choose my plan ↑</a>
    <p class="text-xs text-ink-700/60 mt-5">💬 Questions first? <a href="mailto:jolly@digitalchiselco.com" class="text-bronze-600">Send a message anytime</a>. A real person reads and replies.</p>
  </section>

  <script is:inline>
    const form = document.getElementById('member-form');
    const msg  = document.getElementById('m-msg');
    let action = 'add';
    form.querySelectorAll('button[type=submit]').forEach((b) => b.addEventListener('click', () => { action = b.dataset.action; }));

    // visual select-on-click for plan cards
    document.querySelectorAll('.plan-card').forEach((card) => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.plan-radio').forEach((r) => r.checked = false);
        const radio = card.querySelector('.plan-radio');
        if (radio) radio.checked = true;
        document.querySelectorAll('.plan-card').forEach((c) => c.classList.remove('border-bronze-600', 'bg-cream/40'));
        card.classList.add('border-bronze-600', 'bg-cream/40');
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name  = document.getElementById('m-name').value.trim();
      const email = document.getElementById('m-email').value.trim();
      const picked = document.querySelector('.plan-radio:checked');
      const card = picked?.closest('.plan-card');
      const planSlug  = card?.dataset.slug;
      const planName  = card?.dataset.name;
      const planPrice = Number(card?.dataset.price || 0);
      if (!planSlug) { msg.className = 'sm:col-span-2 text-sm text-red-600'; msg.textContent = 'Please choose a plan above.'; return; }
      msg.className = 'sm:col-span-2 text-sm text-ink-700'; msg.textContent = 'Saving…';
      try {
        const res = await fetch('/api/membership-lead', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ name, email, plan_slug: planSlug }) });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Network error');
        const cart = JSON.parse(localStorage.getItem('cart') || '[]');
        const cartId = 'membership:' + planSlug;
        if (!cart.find((x) => x.id === cartId)) {
          cart.push({ id: cartId, slug: 'membership', title: planName, price: planPrice, img: '' });
          localStorage.setItem('cart', JSON.stringify(cart));
        }
        window.dispatchEvent(new Event('cart-changed'));
        msg.className = 'sm:col-span-2 text-sm text-green-700';
        msg.textContent = '✓ Saved! Redirecting to cart…';
        setTimeout(() => { window.location.href = '/cart'; }, 700);
      } catch (err) {
        msg.className = 'sm:col-span-2 text-sm text-red-600';
        msg.textContent = err.message || 'Something went wrong. Try again.';
      }
    });
  </script>
</Shell>
