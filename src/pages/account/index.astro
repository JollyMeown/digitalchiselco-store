---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { verifyAccountToken } from '../../lib/account-token';
import { img } from '../../lib/img';

export const prerender = false;

const COOKIE = 'dcc_account';
const MAX_AGE = 60 * 60 * 24 * 30;

// NOTE: we used to redirect after sign-in to drop ?token=… from the URL.
// That broke with ERR_TOO_MANY_REDIRECTS because the Netlify Edge in front
// of the SSR function silently appends the inbound query string to any
// same-host Location header — so `/account?token=…` would redirect to
// `/account?token=…` forever. We now render the dashboard on the same
// request, set the cookie via response header, and use a tiny inline
// script to strip the token from the URL client-side via history.replaceState.
function cookieHeader(value: string, maxAgeSec: number): string {
  const parts = [`${COOKIE}=${value}`, `Max-Age=${maxAgeSec}`, 'Path=/', 'HttpOnly', 'SameSite=Lax'];
  if (Astro.url.protocol === 'https:') parts.push('Secure');
  return parts.join('; ');
}

// Determine the session.
const urlToken = Astro.url.searchParams.get('token');
const cookieToken = Astro.cookies.get(COOKIE)?.value;
const isSignOut = Astro.url.searchParams.get('signout') === '1';
let session: { email: string } | null = null;
let cleanUrlAfterRender = false;

if (isSignOut) {
  // Clear cookie, render the sign-in form below.
  Astro.response.headers.append('Set-Cookie',
    `${COOKIE}=; Max-Age=0; Path=/; HttpOnly; SameSite=Lax${Astro.url.protocol === 'https:' ? '; Secure' : ''}`);
  cleanUrlAfterRender = true;
  // intentionally leave `session` null — even though the cookie is still in
  // the inbound request, this render must show the signed-out state.
} else if (urlToken) {
  // Magic-link sign-in: validate, set cookie via header, render dashboard now.
  const ok = verifyAccountToken(urlToken);
  if (ok) {
    session = ok;
    Astro.response.headers.append('Set-Cookie', cookieHeader(urlToken, MAX_AGE));
    cleanUrlAfterRender = true;
  } else {
    // Invalid token — fall back to whatever the cookie says.
    const sess = verifyAccountToken(cookieToken);
    if (sess) session = sess;
  }
} else {
  // Plain visit — try the cookie.
  const sess = verifyAccountToken(cookieToken);
  if (sess) session = sess;
}

type DownloadRow = { file_name: string | null; download_link: string };
type CustomizationField = { key: string; label: string; type: string; value: string };
type OrderItem = {
  id: string; title: string; qty: number; price_usd: number; product_id: string | null;
  downloads?: DownloadRow[];
  image_url?: string | null;
  is_customized?: boolean;
  customization_fields?: CustomizationField[];
  order_item_customizations?: { fields: CustomizationField[] }[];
  products?: { image_url: string | null; slug: string | null; is_customizable: boolean } | null;
};
type OrderRow = { id: string; total: number; currency: string; status: string; created_at: string; paddle_transaction_id: string | null; order_items: OrderItem[] };

let orders: OrderRow[] = [];
let paidCount = 0;
let totalSpent = 0;
let totalFiles = 0;
if (session?.email) {
  const db = supabaseAdmin();
  const { data } = await db
    .from('orders')
    .select('id, total, currency, status, created_at, paddle_transaction_id, order_items(id, title, qty, price_usd, product_id, order_item_customizations(fields), products(image_url, slug, is_customizable))')
    .ilike('email', session.email)
    .order('created_at', { ascending: false })
    .limit(100);
  orders = (data as OrderRow[]) || [];

  const productIds = Array.from(
    new Set(orders.flatMap((o) => (o.order_items || []).map((i) => i.product_id)).filter(Boolean)),
  ) as string[];

  const downloadsByProduct: Record<string, DownloadRow[]> = {};
  if (productIds.length) {
    const { data: dls } = await db
      .from('product_downloads')
      .select('product_id, file_name, download_link')
      .in('product_id', productIds);
    for (const d of (dls || []) as any[]) {
      (downloadsByProduct[d.product_id] ||= []).push({ file_name: d.file_name, download_link: d.download_link });
    }
  }
  for (const o of orders) {
    for (const it of o.order_items || []) {
      const fields = (it.order_item_customizations || []).flatMap((c) => Array.isArray(c.fields) ? c.fields : []);
      it.customization_fields = fields;
      it.is_customized = fields.length > 0 || !!it.products?.is_customizable;
      it.image_url = it.products?.image_url || null;
      // Customized lines never show static download links — the file is built post-purchase.
      it.downloads = it.is_customized ? [] : ((it.product_id && downloadsByProduct[it.product_id]) || []);
    }
  }
  const paidOrders = orders.filter((o) => o.status === 'paid');
  paidCount = paidOrders.length;
  totalSpent = paidOrders.reduce((s, o) => s + Number(o.total || 0), 0);
  totalFiles = paidOrders.reduce((n, o) => n + (o.order_items || []).reduce((m, it) => m + (it.downloads || []).length, 0), 0);
}
---
<Base title="My Account · DigitalChiselCo" noindex>
  <Header />
  {cleanUrlAfterRender && (
    <script is:inline>
      try { history.replaceState(null, '', '/account'); } catch (_) { /* noop */ }
    </script>
  )}
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-12 min-h-[60vh]">
    {!session ? (
      <section class="max-w-md mx-auto">
        <h1 class="font-serif text-3xl text-bronze-800 mb-3">Your account</h1>
        <p class="text-ink-700 mb-6">
          Enter the email you used at checkout — we'll send you a secure link to view all your past orders and re-download your STL files.
        </p>
        <form id="signin" class="space-y-3">
          <input id="email" type="email" required placeholder="you@email.com" autocomplete="email"
            class="w-full px-4 py-3 rounded-md border border-bronze-600/30 focus:outline-none focus:border-bronze-600 bg-white" />
          <button type="submit"
            class="w-full bg-bronze-600 text-cream px-6 py-3 rounded-md hover:bg-bronze-700 transition">
            Email me a sign-in link
          </button>
        </form>
        <p id="msg" class="mt-4 text-sm hidden"></p>
        <p class="mt-8 text-xs text-ink-700/60">
          New here? Browse the <a href="/catalog" class="text-bronze-600 underline">catalog</a> or get a
          <a href="/free" class="text-bronze-600 underline">free STL pack</a>.
        </p>
      </section>
    ) : (
      <section>
        <div class="flex justify-between flex-wrap gap-3 items-start mb-6">
          <div>
            <h1 class="font-serif text-3xl text-bronze-800">My orders</h1>
            <p class="text-ink-700/70 text-sm mt-1">Signed in as <strong>{session.email}</strong></p>
          </div>
          <a href="/account?signout=1" class="text-sm text-bronze-600 underline" data-signout>Sign out</a>
        </div>
        {orders.length === 0 ? (
          <div class="bg-cream/40 border border-bronze-600/20 rounded-lg p-8 text-center">
            <div class="text-5xl mb-3" aria-hidden="true">📭</div>
            <p class="text-ink-700">No orders found under <strong>{session.email}</strong>.</p>
            <p class="text-sm text-ink-700/70 mt-2">
              If you bought files using a different email, <a href="/account?signout=1" class="text-bronze-600 underline" data-signout>sign out</a> and try again.
            </p>
            <a href="/catalog" class="inline-block mt-5 bg-bronze-600 hover:bg-bronze-700 text-cream px-5 py-2.5 rounded-md text-sm">Browse the catalog →</a>
          </div>
        ) : (
          <>
            {/* Stats strip */}
            <div class="grid grid-cols-3 gap-3 mb-6">
              <div class="bg-cream/40 border border-bronze-600/20 rounded-lg p-4 text-center">
                <div class="text-2xl font-medium text-bronze-800">{paidCount}</div>
                <div class="text-[11px] uppercase tracking-wide text-bronze-700/70 mt-0.5">Paid orders</div>
              </div>
              <div class="bg-cream/40 border border-bronze-600/20 rounded-lg p-4 text-center">
                <div class="text-2xl font-medium text-bronze-800">{'$' + totalSpent.toFixed(0)}</div>
                <div class="text-[11px] uppercase tracking-wide text-bronze-700/70 mt-0.5">Total spent</div>
              </div>
              <div class="bg-cream/40 border border-bronze-600/20 rounded-lg p-4 text-center">
                <div class="text-2xl font-medium text-bronze-800">{totalFiles}</div>
                <div class="text-[11px] uppercase tracking-wide text-bronze-700/70 mt-0.5">Files available</div>
              </div>
            </div>

            <div class="space-y-6">
              {orders.map((o) => {
                const itemCount = (o.order_items || []).reduce((s, it) => s + (Number(it.qty) || 1), 0);
                const downloadCount = (o.order_items || []).reduce((s, it) => s + (it.downloads?.length || 0), 0);
                const statusClasses: any = {
                  paid: 'bg-green-100 text-green-800',
                  pending: 'bg-yellow-100 text-yellow-800',
                  refunded: 'bg-purple-100 text-purple-800',
                  failed: 'bg-red-100 text-red-800',
                  canceled: 'bg-gray-100 text-gray-700',
                };
                const statusClass = statusClasses[o.status] || 'bg-gray-100 text-gray-700';
                return (
                  <div class="bg-white border border-black/10 rounded-xl p-5">
                    <div class="flex justify-between flex-wrap gap-2 items-baseline mb-4">
                      <div>
                        <div class="flex items-center gap-2 flex-wrap">
                          <span class="font-medium text-ink-800">Order #{String(o.id).slice(0, 8)}</span>
                          <span class={`text-xs px-2 py-0.5 rounded ${statusClass}`}>{o.status}</span>
                        </div>
                        <div class="text-xs text-ink-700/60 mt-1">
                          {new Date(o.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                          {' · '}{itemCount} item{itemCount === 1 ? '' : 's'}
                          {downloadCount > 0 && ` · ${downloadCount} file${downloadCount === 1 ? '' : 's'} available`}
                        </div>
                      </div>
                      <div class="text-sm text-ink-700/80 whitespace-nowrap">${Number(o.total).toFixed(2)} {o.currency || 'USD'}</div>
                    </div>
                    <ul class="divide-y divide-black/10">
                      {(o.order_items || []).map((it) => (
                        <li class="py-3">
                          <div class="flex gap-4">
                            {/* Medium product thumbnail */}
                            <a href={it.products?.slug ? `/product/${it.products.slug}` : '#'} class="block w-20 h-20 sm:w-24 sm:h-24 rounded-md overflow-hidden bg-cream/60 flex-shrink-0">
                              {it.image_url
                                ? <img src={img(it.image_url, { w: 200, q: 75 })} alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                                : <div class="w-full h-full flex items-center justify-center text-bronze-600/30 text-xs">no image</div>}
                            </a>
                            <div class="flex-1 min-w-0">
                              <div class="flex justify-between items-baseline gap-3 mb-2">
                                <div class="text-sm text-ink-800">
                                  {it.products?.slug
                                    ? <a href={`/product/${it.products.slug}`} class="hover:text-bronze-600">{it.title}</a>
                                    : it.title}
                                  {it.is_customized && <span class="ml-2 inline-block bg-[#FAC775] text-bronze-900 text-[10px] font-semibold tracking-wider uppercase px-1.5 py-0.5 rounded align-middle">✎ Custom</span>}
                                </div>
                                <span class="text-xs text-ink-700/60 whitespace-nowrap">{it.qty}× ${Number(it.price_usd).toFixed(2)}</span>
                              </div>
                              {it.is_customized ? (
                                <div class="space-y-2">
                                  <div class="text-xs text-bronze-800 bg-cream/60 border-l-2 border-bronze-600 pl-3 py-2 rounded-r leading-relaxed">
                                    ✨ <strong>Your custom design request is in.</strong> Our team is hand-crafting your one-of-a-kind STL. We'll email the download link once it's ready — and reach out separately if we need any clarification.
                                  </div>
                                  {it.customization_fields && it.customization_fields.length > 0 && (
                                    <details class="text-xs">
                                      <summary class="cursor-pointer text-ink-700/70 hover:text-bronze-700 select-none">View your submitted details</summary>
                                      <dl class="mt-2 ml-3 space-y-1 text-ink-700">
                                        {it.customization_fields.map((f) => (
                                          <div class="grid grid-cols-[120px_1fr] gap-2">
                                            <dt class="text-ink-700/60">{f.label || f.key}</dt>
                                            <dd class="break-words">
                                              {f.type === 'file_url' && f.value
                                                ? <a href={f.value} target="_blank" class="text-bronze-600 underline break-all">{f.value}</a>
                                                : <span class="whitespace-pre-wrap">{f.value || <em class="text-ink-700/40">(empty)</em>}</span>}
                                            </dd>
                                          </div>
                                        ))}
                                      </dl>
                                    </details>
                                  )}
                                </div>
                              ) : it.downloads && it.downloads.length > 0 ? (
                                <div class="flex flex-wrap gap-2">
                                  {it.downloads.map((d, i) => (
                                    <a href={d.download_link} target="_blank" rel="noopener"
                                      class="inline-flex items-center bg-bronze-600 hover:bg-bronze-700 text-cream px-4 py-2 rounded-md text-sm transition">
                                      ⬇ Download{it.downloads!.length > 1 ? ` file ${i + 1}` : ''}{d.file_name && it.downloads!.length === 1 ? ` · ${d.file_name}` : ''}
                                    </a>
                                  ))}
                                </div>
                              ) : (
                                <div class="text-xs text-ink-700/60 italic">
                                  Download link will be emailed within a few minutes if not already attached.
                                </div>
                              )}
                            </div>
                          </div>
                        </li>
                      ))}
                    </ul>
                  </div>
                );
              })}
            </div>
          </>
        )}
      </section>
    )}
  </main>
  <Footer />

  {!session && (
    <script is:inline>
      const form = document.getElementById('signin');
      const msg = document.getElementById('msg');
      const emailInput = document.getElementById('email');
      const button = form?.querySelector('button[type="submit"]');
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = emailInput.value.trim();
        msg.className = 'mt-4 text-sm text-ink-700';
        msg.textContent = 'Sending sign-in link…';
        msg.classList.remove('hidden');
        button.disabled = true;
        try {
          const res = await fetch('/api/account/request-link', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();
          if (res.ok && data.ok) {
            msg.className = 'mt-4 text-sm text-green-700';
            msg.textContent = '✓ Check ' + email + ' for your sign-in link. (Valid for 30 days.)';
            form.reset();
          } else {
            msg.className = 'mt-4 text-sm text-red-700';
            msg.textContent = data?.error || 'Something went wrong. Please try again.';
          }
        } catch {
          msg.className = 'mt-4 text-sm text-red-700';
          msg.textContent = 'Network error. Please try again.';
        } finally {
          button.disabled = false;
        }
      });
    </script>
  )}
</Base>
